generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tour {
  id          String   @id @default(cuid())
  title       String
  titleKz     String   @default("")
  description String
  descriptionKz String  @default("")
  route       String?
  routeKz     String?
  price       Float
  childPrice  Float?
  duration    Int
  category    String
  isPublished Boolean  @default(false)
  images      Image[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Image {
  id     String @id @default(cuid())
  url    String
  tour   Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  tourId String
  order  Int    @default(0)
}

model Settings {
  id          String  @id @default("main")
  whatsappNum String  @default("77059652303")
  companyName String  @default("Altosh Travel")
  contactInfo String?
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String
}
